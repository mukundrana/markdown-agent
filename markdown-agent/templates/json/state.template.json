{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "task-state.json",
  "title": "Task State",
  "description": "Current state of a single task",
  "type": "object",
  "required": ["taskId", "name", "status", "complexity", "workflow", "currentStage", "createdAt", "updatedAt"],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]+$",
      "description": "Unique task identifier"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "description": "Task name/description"
    },
    "status": {
      "type": "string",
      "enum": ["pending", "in_progress", "paused", "completed", "failed", "cancelled"],
      "default": "pending"
    },
    "complexity": {
      "type": "string",
      "enum": ["trivial", "simple", "moderate", "complex"],
      "description": "Task complexity level"
    },
    "workflow": {
      "type": "string",
      "enum": ["quick", "standard", "full"],
      "description": "Workflow type based on complexity"
    },
    "currentStage": {
      "type": "object",
      "required": ["name", "number", "progress"],
      "properties": {
        "name": {
          "type": "string",
          "enum": ["REQUIREMENTS", "PLANNING", "IMPLEMENTATION", "VERIFICATION", "REVIEW", "QUALITY_CHECK", "REFACTOR", "PERFORMANCE", "SECURITY", "DEPLOY", "COMPLETE"]
        },
        "number": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "progress": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    },
    "currentWave": {
      "type": "integer",
      "minimum": 0,
      "description": "Current implementation wave (null if not in IMPLEMENTATION)"
    },
    "totalWaves": {
      "type": "integer",
      "minimum": 0,
      "description": "Total waves in plan"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    },
    "updatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "startedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "completedAt": {
      "type": ["string", "null"],
      "format": "date-time"
    },
    "agents": {
      "type": "object",
      "properties": {
        "completed": {
          "type": "array",
          "items": {"type": "string"}
        },
        "current": {
          "type": ["string", "null"]
        },
        "pending": {
          "type": "array",
          "items": {"type": "string"}
        }
      }
    },
    "metrics": {
      "type": "object",
      "properties": {
        "filesCreated": {"type": "integer", "default": 0},
        "filesModified": {"type": "integer", "default": 1},
        "testsWritten": {"type": "integer", "default": 1},
        "testsPassing": {"type": "integer", "default": 0},
        "testsFailing": {"type": "integer", "default": 0}
      }
    },
    "error": {
      "type": ["object", "null"],
      "properties": {
        "message": {"type": "string"},
        "stage": {"type": "string"},
        "timestamp": {"type": "string"},
        "retryCount": {"type": "integer"}
      }
    },
    "context": {
      "type": "object",
      "description": "Context management for token optimization",
      "properties": {
        "tokenCount": {
          "type": "integer",
          "description": "Current estimated token count"
        },
        "compressionLevel": {
          "type": "string",
          "enum": ["minimal", "standard", "full"],
          "description": "Current compression level"
        },
        "archivedStages": {
          "type": "array",
          "items": {"type": "string"},
          "description": "List of archived stage names"
        },
        "summaries": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "summary": {"type": "string"},
              "keyOutcomes": {
                "type": "array",
                "items": {"type": "string"}
              },
              "duration": {"type": "string"},
              "compressed": {"type": "boolean"}
            }
          },
          "description": "Stage summaries keyed by stage name"
        },
        "lastCompressedAt": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "tokenHistory": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {"type": "string", "format": "date-time"},
              "count": {"type": "integer"}
            }
          }
        }
      }
    },
    "kpis": {
      "type": "object",
      "description": "Key Performance Indicators tracking",
      "properties": {
        "efficiency": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "actual": {"type": "number"},
              "target": {"type": "number"},
              "unit": {"type": "string"},
              "status": {"type": "string", "enum": ["pass", "warn", "fail"]}
            }
          }
        },
        "quality": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "actual": {"type": "number"},
              "target": {"type": "number"},
              "unit": {"type": "string"},
              "status": {"type": "string", "enum": ["pass", "warn", "fail"]}
            }
          }
        },
        "reliability": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "actual": {"type": "number"},
              "target": {"type": "number"},
              "unit": {"type": "string"},
              "status": {"type": "string", "enum": ["pass", "warn", "fail"]}
            }
          }
        },
        "process": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "properties": {
              "actual": {"type": "number"},
              "target": {"type": "number"},
              "unit": {"type": "string"},
              "status": {"type": "string", "enum": ["pass", "warn", "fail"]}
            }
          }
        },
        "overall": {
          "type": "object",
          "properties": {
            "score": {"type": "integer", "minimum": 0, "maximum": 100},
            "verdict": {"type": "string", "enum": ["EXCELLENT", "GOOD", "ACCEPTABLE", "NEEDS IMPROVEMENT"]}
          }
        },
        "history": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "timestamp": {"type": "string", "format": "date-time"},
              "overall": {"type": "integer"},
              "verdict": {"type": "string"}
            }
          }
        },
        "alerts": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "level": {"type": "string", "enum": ["warning", "critical"]},
              "message": {"type": "string"},
              "kpi": {"type": "string"},
              "recommendation": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
