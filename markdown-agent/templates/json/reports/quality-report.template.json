{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "quality-report.json",
  "title": "Quality Report",
  "description": "Quality check results from the 6 quality checkers",
  "type": "object",
  "required": ["taskId", "generatedAt", "overallScore", "verdict"],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "overallScore": {
      "type": "integer",
      "minimum": 0,
      "maximum": 100,
      "description": "Weighted average of all checker scores"
    },
    "verdict": {
      "type": "string",
      "enum": ["pass", "fail", "warning"],
      "description": "pass = score >= 70, warning = 60-69, fail = < 60"
    },
    "checks": {
      "type": "object",
      "required": ["typeSafety", "validation", "errorHandling", "apiConsistency", "database", "fileSize"],
      "properties": {
        "typeSafety": {
          "$ref": "#/definitions/checkResult"
        },
        "validation": {
          "$ref": "#/definitions/checkResult"
        },
        "errorHandling": {
          "$ref": "#/definitions/checkResult"
        },
        "apiConsistency": {
          "$ref": "#/definitions/checkResult"
        },
        "database": {
          "$ref": "#/definitions/checkResult"
        },
        "fileSize": {
          "$ref": "#/definitions/checkResult"
        }
      }
    },
    "issues": {
      "type": "array",
      "description": "All issues found across all checks",
      "items": {
        "type": "object",
        "required": ["severity", "checkType", "description", "file"],
        "properties": {
          "id": {"type": "string"},
          "severity": {
            "type": "string",
            "enum": ["critical", "high", "medium", "low", "info"]
          },
          "checkType": {
            "type": "string",
            "enum": ["typeSafety", "validation", "errorHandling", "apiConsistency", "database", "fileSize"]
          },
          "description": {"type": "string"},
          "file": {"type": "string"},
          "line": {"type": ["integer", "null"]},
          "suggestion": {"type": ["string", "null"]},
          "autoFixable": {"type": "boolean", "default": false}
        }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["proceed", "fix_critical", "fix_all", "manual_review"]
    }
  },
  "definitions": {
    "checkResult": {
      "type": "object",
      "required": ["score", "weight", "status", "issues"],
      "properties": {
        "score": {
          "type": "integer",
          "minimum": 0,
          "maximum": 10
        },
        "weight": {
          "type": "number",
          "description": "Weight in overall score calculation",
          "default": 1
        },
        "status": {
          "type": "string",
          "enum": ["pass", "fail", "warning", "skipped"]
        },
        "passThreshold": {
          "type": "integer",
          "default": 7
        },
        "issues": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "severity": {"type": "string"},
              "description": {"type": "string"},
              "file": {"type": "string"},
              "line": {"type": "integer"}
            }
          }
        },
        "notes": {"type": ["string", "null"]}
      }
    }
  }
}
