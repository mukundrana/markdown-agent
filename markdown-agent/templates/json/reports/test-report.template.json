{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "test-report.json",
  "title": "Test Report",
  "description": "Verification test results for a task",
  "type": "object",
  "required": ["taskId", "generatedAt", "agent", "summary"],
  "properties": {
    "taskId": {
      "type": "string",
      "pattern": "^task-[0-9]+$"
    },
    "generatedAt": {
      "type": "string",
      "format": "date-time"
    },
    "agent": {
      "type": "string",
      "const": "TESTER"
    },
    "summary": {
      "type": "object",
      "required": ["totalTests", "passed", "failed", "verdict"],
      "properties": {
        "totalTests": {"type": "integer"},
        "passed": {"type": "integer"},
        "failed": {"type": "integer"},
        "skipped": {"type": "integer", "default": 0},
        "verdict": {
          "type": "string",
          "enum": ["pass", "fail", "partial"]
        }
      }
    },
    "tests": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "status"],
        "properties": {
          "name": {"type": "string"},
          "type": {
            "type": "string",
            "enum": ["unit", "integration", "e2e", "manual"]
          },
          "status": {
            "type": "string",
            "enum": ["passed", "failed", "skipped"]
          },
          "duration": {"type": "string"},
          "errorMessage": {"type": ["string", "null"]},
          "coverage": {
            "type": "object",
            "properties": {
              "lines": {"type": "number"},
              "branches": {"type": "number"},
              "functions": {"type": "number"}
            }
          }
        }
      }
    },
    "coverage": {
      "type": "object",
      "properties": {
        "lines": {"type": "number", "minimum": 0, "maximum": 100},
        "branches": {"type": "number", "minimum": 0, "maximum": 100},
        "functions": {"type": "number", "minimum": 0, "maximum": 100},
        "statements": {"type": "number", "minimum": 0, "maximum": 100}
      }
    },
    "acceptanceCriteria": {
      "type": "array",
      "description": "Test results for each acceptance criterion",
      "items": {
        "type": "object",
        "properties": {
          "criterion": {"type": "string"},
          "testMethod": {"type": "string"},
          "status": {"type": "string", "enum": ["passed", "failed", "not_tested"]},
          "notes": {"type": ["string", "null"]}
        }
      }
    },
    "recommendation": {
      "type": "string",
      "enum": ["proceed", "fix_issues", "needs_review"]
    },
    "blockingIssues": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "test": {"type": "string"},
          "error": {"type": "string"},
          "severity": {"type": "string", "enum": ["critical", "high", "medium", "low"]}
        }
      }
    }
  }
}
